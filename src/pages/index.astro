---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import "../styles/global.css";

const stack = ["Python", "LangGraph", "FastAPI", "React", "Postgres", "Vision AI"];
const signalCards = [
  { label: "Current focus", value: "AI + product engineering" },
  { label: "Mode", value: "Building and shipping systems" },
  { label: "Open to", value: "Senior software opportunities" }
];

const experienceHighlights = [
  {
    window: "Recent",
    role: "Senior Software Engineer",
    detail: "Building practical software with a product-first lens across backend APIs, AI orchestration, and frontend delivery."
  },
  {
    window: "Core lane",
    role: "AI Systems Builder",
    detail: "Designing structured-data workflows where LLMs and automation support real product outcomes instead of demos."
  },
  {
    window: "Always",
    role: "Systems-minded Developer",
    detail: "Prioritizing clarity, documentation, and maintainable architecture so projects can scale over time."
  }
];

const hobbyProjects = [
  {
    title: "SightLoop Console",
    subtitle: "formerly Habit Tracker",
    href: "https://github.com/veerthiara/HabitTracker",
    body: "Tracks routines, logs events, and layers AI summaries on top of structured data."
  },
  {
    title: "SightLoop Vision",
    subtitle: "camera + Vision AI",
    href: "/projects/habit-tracker/",
    body: "Computer-vision path that detects real-world actions and feeds them back into the Console."
  }
];

const particles = [
  { x: "8%", y: "18%", size: "8px", delay: "0s", duration: "14s", color: "var(--marketing-cyan)" },
  { x: "18%", y: "62%", size: "6px", delay: "2s", duration: "18s", color: "var(--marketing-blue)" },
  { x: "27%", y: "34%", size: "10px", delay: "1s", duration: "16s", color: "rgba(255, 184, 77, 0.9)" },
  { x: "36%", y: "78%", size: "7px", delay: "5s", duration: "20s", color: "rgba(242, 112, 156, 0.72)" },
  { x: "43%", y: "14%", size: "9px", delay: "3s", duration: "17s", color: "var(--marketing-blue)" },
  { x: "51%", y: "56%", size: "5px", delay: "6s", duration: "15s", color: "var(--marketing-cyan)" },
  { x: "59%", y: "28%", size: "11px", delay: "2.5s", duration: "19s", color: "rgba(255, 184, 77, 0.85)" },
  { x: "66%", y: "74%", size: "6px", delay: "4s", duration: "13s", color: "rgba(242, 112, 156, 0.78)" },
  { x: "74%", y: "12%", size: "7px", delay: "7s", duration: "21s", color: "var(--marketing-cyan)" },
  { x: "82%", y: "44%", size: "10px", delay: "2s", duration: "18s", color: "var(--marketing-blue)" },
  { x: "90%", y: "68%", size: "8px", delay: "5.5s", duration: "16s", color: "rgba(255, 184, 77, 0.82)" },
  { x: "13%", y: "86%", size: "5px", delay: "8s", duration: "22s", color: "var(--marketing-cyan)" }
];
---

<MarketingLayout
  title="Veer Thiara | Developer Portfolio"
  description="Developer portfolio, current projects, and engineering notes."
>
  <div class="marketing-shell">
    <div class="marketing-background">
      <span class="marketing-glow marketing-glow-a"></span>
      <span class="marketing-glow marketing-glow-b"></span>
      <span class="marketing-glow marketing-glow-c"></span>
      <span class="marketing-aurora marketing-aurora-a"></span>
      <span class="marketing-aurora marketing-aurora-b"></span>
      <span class="marketing-rings"></span>
      <div class="marketing-dna" aria-hidden="true">
        <span class="dna-strand dna-strand-a"></span>
        <span class="dna-strand dna-strand-b"></span>
        <span class="dna-rung dna-rung-1"></span>
        <span class="dna-rung dna-rung-2"></span>
        <span class="dna-rung dna-rung-3"></span>
        <span class="dna-rung dna-rung-4"></span>
        <span class="dna-rung dna-rung-5"></span>
        <span class="dna-rung dna-rung-6"></span>
      </div>
      <div class="marketing-particles" aria-hidden="true">
        {particles.map((particle) => (
          <span
            class="marketing-particle"
            style={`left:${particle.x};top:${particle.y};width:${particle.size};height:${particle.size};animation-delay:${particle.delay};animation-duration:${particle.duration};--particle-color:${particle.color};`}
          ></span>
        ))}
      </div>
      <span class="marketing-grid"></span>
    </div>

    <header class="marketing-header">
      <a class="marketing-brand" href="/">
        <span class="marketing-brand-mark">VT</span>
        <span class="marketing-brand-copy">
          <strong>Veer Thiara</strong>
          <small>Developer portfolio</small>
        </span>
      </a>

      <nav class="marketing-nav" aria-label="Primary">
        <a href="/projects/">Projects</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
        <a href="https://www.linkedin.com/in/veerthiara/" target="_blank" rel="noreferrer">LinkedIn</a>
      </nav>
    </header>

    <main class="marketing-main">
      <section class="hero">
        <div class="hero-copy">
          <p class="hero-eyebrow">Professional snapshot</p>
          <h1>
            Hi, I'm
            <span>Veer Thiara</span>,
            a builder focused on software + AI systems.
          </h1>
          <p class="hero-lead">
            A quick look at what I build: experience highlights, current technical focus,
            and hobby projects I am actively growing.
          </p>

          <div class="hero-actions">
            <a class="button-primary" href="https://www.linkedin.com/in/veerthiara/" target="_blank" rel="noreferrer">View LinkedIn</a>
            <a class="button-secondary" href="/projects/">Explore Projects</a>
          </div>

          <ul class="hero-stack" aria-label="Current stack">
            {stack.map((item) => <li>{item}</li>)}
          </ul>

          <div class="hero-signal-grid">
            {signalCards.map((card) => (
              <div class="hero-signal-card">
                <span>{card.label}</span>
                <strong>{card.value}</strong>
              </div>
            ))}
          </div>
        </div>

        <div class="hero-panel" aria-hidden="true">
          <div class="hero-visual">
            <div class="hero-profile-block">
              <div class="hero-profile-image-wrap">
                <div class="hero-profile-image" role="img" aria-label="Profile image placeholder">VT</div>
              </div>
              <div class="hero-profile-copy">
                <span>Veer Thiara</span>
                <strong>Senior Software Engineer</strong>
                <small>Product engineering • AI systems • Full stack delivery</small>
              </div>
            </div>

            <div class="hero-floating-card hero-floating-card-a">
              <span>Experience</span>
              <strong>Senior software engineering</strong>
            </div>

            <div class="hero-floating-card hero-floating-card-b">
              <span>Hobby build</span>
              <strong>SightLoop Console + Vision</strong>
            </div>

            <div class="hero-panel-window">
              <div class="window-dots">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <pre><code>{`async function shipUsefulSoftware() {
  const focus = ["projects", "docs", "notes"];
  const approach = "build-first";
  const systems = await orchestrate({
    backend: "FastAPI",
    ai: "LangGraph",
    storage: "Postgres"
  });

  return { focus, approach, systems };
}`}</code></pre>
            </div>
          </div>
        </div>
      </section>

      <section class="motion-strip" aria-label="Animated technology strip">
        <div class="motion-strip-track">
          {[...stack, "AI Systems", "Local First", "Engineering Notes", "Developer Portal", ...stack].map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </section>

      <section class="section-grid">
        <div class="section-intro">
          <p class="section-label">Experience</p>
          <h2>Professional summary and highlights from my engineering journey.</h2>
          <p>
            A concise overview of my engineering lane: building useful products, designing clear systems,
            and iterating quickly from idea to shipped software.
          </p>
        </div>

        <div class="card-grid">
          {experienceHighlights.map((item) => (
            <article class="feature-card">
              <span class="feature-card-label">{item.window}</span>
              <strong>{item.role}</strong>
              <p>{item.detail}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="scroll-teaser">
        <div>
          <p class="section-label">Hobby Projects</p>
          <h2>Projects I’m actively developing outside core work.</h2>
          <p>
            These two projects reflect where I spend extra build time right now: a robust console,
            and a camera-first Vision AI layer that extends it.
          </p>

          <div class="hobby-project-grid">
            {hobbyProjects.map((item, index) => (
              <a class:list={["feature-card", `feature-card-${index === 0 ? "mint" : "amber"}`]} href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
                <span class="feature-card-label">{item.subtitle}</span>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    </main>
  </div>
</MarketingLayout>
